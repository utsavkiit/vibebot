# Copy this file to .env and fill in your values.
# .env is gitignored — never commit your real secrets.

# ---------------------------------------------------------------------------
# LLM API keys
# Set the key for whichever provider is configured in config.yaml.
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here   # optional — only needed if provider=openai

# ---------------------------------------------------------------------------
# News
# Sign up for a free key at https://newsapi.org/register
# ---------------------------------------------------------------------------
NEWS_API_KEY=your_newsapi_key_here

# ---------------------------------------------------------------------------
# Slack Incoming Webhook
# 1. Go to https://api.slack.com/apps and create (or open) your app.
# 2. Navigate to "Incoming Webhooks" and enable it.
# 3. Click "Add New Webhook to Workspace" and choose a channel.
# 4. Copy the generated URL below.
# ---------------------------------------------------------------------------
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
