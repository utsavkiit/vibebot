# Copy this file to .env and fill in your values.
# .env is gitignored — never commit your real secrets.

# ---------------------------------------------------------------------------
# LLM API keys
# Set the key for whichever provider is configured in config.yaml.
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here   # optional — only needed if provider=openai

# ---------------------------------------------------------------------------
# News
# Sign up for a free key at https://newsapi.org/register
# ---------------------------------------------------------------------------
NEWS_API_KEY=your_newsapi_key_here

# ---------------------------------------------------------------------------
# Slack Incoming Webhooks (per-plugin)
# Each plugin sends to its own webhook so messages go to separate channels.
# 1. Go to https://api.slack.com/apps and create (or open) your app.
# 2. Navigate to "Incoming Webhooks" and enable it.
# 3. Add a webhook per channel and copy the URLs below.
#
# SLACK_WEBHOOK_URL is used as a fallback for any channel without a dedicated URL.
# ---------------------------------------------------------------------------
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SLACK_WEBHOOK_URL_NEWS=https://hooks.slack.com/services/YOUR/NEWS/WEBHOOK
SLACK_WEBHOOK_URL_PORSCHE_MACAN=https://hooks.slack.com/services/YOUR/PORSCHE/WEBHOOK

# ---------------------------------------------------------------------------
# Porsche Macan listings — auto.dev
# Sign up for a free key at https://www.auto.dev/
# ---------------------------------------------------------------------------
AUTO_DEV_API_KEY=your_auto_dev_api_key_here
